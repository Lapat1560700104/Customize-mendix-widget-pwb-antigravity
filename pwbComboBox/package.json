{
  "name": "pwbcombobox",
  "widgetName": "PwbComboBox",
  "version": "3.11.0",
  "description": "Premium highly customizable ComboBox with search autocomplete.",
  "copyright": "PWB 2026",
  "author": "Antigravity",
  "engines": {
    "node": ">=16"
  },
  "license": "Apache-2.0",
  "config": {
    "projectPath": "../../",
    "mendixHost": "http://localhost:8080",
    "developmentPort": 3000
  },
  "packagePath": "pwb",
  "scripts": {
    "start": "pluggable-widgets-tools start:server",
    "dev": "pluggable-widgets-tools start:web",
    "build": "pluggable-widgets-tools build:web",
    "lint": "pluggable-widgets-tools lint",
    "lint:fix": "pluggable-widgets-tools lint:fix",
    "prebuild": "node ../scripts/sync-xml-version.js",
    "prerelease": "node ../scripts/sync-xml-version.js && npm run lint",
    "release": "pluggable-widgets-tools release:web && node ../scripts/rename_mpk.js",
    "playground": "vite playground"
  },
  "devDependencies": {
    "@mendix/pluggable-widgets-tools": "^11.6.0",
    "@types/big.js": "^6.0.2",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "classnames": "^2.2.6"
  },
  "resolutions": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
