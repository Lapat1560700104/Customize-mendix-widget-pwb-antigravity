<?xml version="1.0" encoding="utf-8"?>
<widget id="pwb.pwbdatepicker.PwbDatePicker" pluginWidget="true" needsEntityContext="true" offlineCapable="true"
        supportedPlatform="Web"
        xmlns="http://www.mendix.com/widget/1.0/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>PWB Advanced DatePicker</name>
    <description>Premium high-performance Date and Range Picker with B.E. support and time sliders.</description>
    <icon/>
    <properties>
        <propertyGroup caption="General">
            <property key="selectionMode" type="enumeration" defaultValue="single">
                <caption>Selection Mode</caption>
                <description>Choose single date selection or start/end date range selection</description>
                <enumerationValues>
                    <enumerationValue key="single">Single Date</enumerationValue>
                    <enumerationValue key="range">Date Range</enumerationValue>
                </enumerationValues>
            </property>
            <property key="dateAttribute" type="attribute" required="false">
                <caption>Date Attribute</caption>
                <description>DateTime attribute for Single selection mode</description>
                <attributeTypes>
                    <attributeType name="DateTime"/>
                </attributeTypes>
            </property>
            <property key="startDateAttribute" type="attribute" required="false">
                <caption>Start Date Attribute</caption>
                <description>DateTime attribute for Range start date</description>
                <attributeTypes>
                    <attributeType name="DateTime"/>
                </attributeTypes>
            </property>
            <property key="endDateAttribute" type="attribute" required="false">
                <caption>End Date Attribute</caption>
                <description>DateTime attribute for Range end date</description>
                <attributeTypes>
                    <attributeType name="DateTime"/>
                </attributeTypes>
            </property>
        </propertyGroup>
        <propertyGroup caption="Features">
            <property key="showTime" type="boolean" defaultValue="false">
                <caption>Show Time Picker</caption>
                <description>Enable time selection (hours and minutes)</description>
            </property>
            <property key="buddhistEra" type="boolean" defaultValue="false">
                <caption>Thai Buddhist Year (พ.ศ.)</caption>
                <description>Show year in Thai Buddhist Era (พ.ศ.) instead of Christian Era (ค.ศ.)</description>
            </property>
            <property key="showPresets" type="boolean" defaultValue="true">
                <caption>Show Presets Panel</caption>
                <description>Show quick selection buttons for fast date pick (e.g. Today, Last 7 Days)</description>
            </property>
            <property key="showEraToggle" type="boolean" defaultValue="true">
                <caption>Show Live Era Switch</caption>
                <description>Show interactive พ.ศ. / ค.ศ. toggle on the calendar header</description>
            </property>
        </propertyGroup>
        <propertyGroup caption="Constraints">
            <property key="minDate" type="expression" required="false">
                <caption>Min Date</caption>
                <description>Minimum date allowed</description>
                <returnType type="DateTime"/>
            </property>
            <property key="maxDate" type="expression" required="false">
                <caption>Max Date</caption>
                <description>Maximum date allowed</description>
                <returnType type="DateTime"/>
            </property>
            <property key="disableWeekends" type="boolean" defaultValue="false">
                <caption>Disable Weekends</caption>
                <description>Disable selection of Saturdays and Sundays</description>
            </property>
        </propertyGroup>
        <propertyGroup caption="Aesthetics">
            <property key="placeholder" type="string" required="false" defaultValue="Select date...">
                <caption>Placeholder Text</caption>
                <description>Input placeholder text</description>
            </property>
            <property key="accentColor" type="string" required="false" defaultValue="#3b82f6">
                <caption>Accent Color (Hex)</caption>
                <description>Accent theme color of the DatePicker (e.g. Hex code: #3b82f6)</description>
            </property>
            <property key="dateFormat" type="string" required="false" defaultValue="DD/MM/YYYY">
                <caption>Date Format</caption>
                <description>Display format for selected date(s) (e.g., DD/MM/YYYY, YYYY-MM-DD)</description>
            </property>
            <property key="borderRadius" type="string" required="false" defaultValue="16px">
                <caption>Border Radius</caption>
                <description>Corner roundness of input and calendar (e.g., 16px, 8px, 0px)</description>
            </property>
            <property key="bgBlur" type="string" required="false" defaultValue="16px">
                <caption>Background Blur</caption>
                <description>Glassmorphism backdrop-filter blur level (e.g., 16px, 8px, 0px to disable)</description>
            </property>
            <property key="popoverBg" type="string" required="false" defaultValue="rgba(255, 255, 255, 0.85)">
                <caption>Calendar Background Color</caption>
                <description>Background fill color of the popover calendar (e.g., rgba(255, 255, 255, 0.85), #ffffff)</description>
            </property>
        </propertyGroup>
    </properties>
</widget>